# ─── Copy this file to .env.local and fill in your values ─────────────────────
# .env.local is gitignored and will NEVER be pushed to GitHub

# Your Strapi instance URL
# Local dev:  http://localhost:1337
# Production: https://your-project.strapiapp.com
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Strapi API Token
# Generate: Strapi Admin → Settings → API Tokens → Create Read-only token
STRAPI_API_TOKEN=your_strapi_api_token_here

# Web3Forms key for the contact form (free at web3forms.com)
WEB3FORMS_KEY=your_web3forms_key_here
